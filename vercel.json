{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(storage|session|files|create-folder|delete-item|search|open-file|firebase|logout|auth|upload-item)(.*)",
      "destination": "https://YOUR-RENDER-BACKEND-URL.onrender.com/$1$2"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
