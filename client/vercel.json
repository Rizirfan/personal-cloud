{
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/(storage|session|files|create-folder|delete-item|search|open-file|firebase|logout|auth|upload-item)(.*)",
      "destination": "https://personal-cloud-ng2q.onrender.com/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
